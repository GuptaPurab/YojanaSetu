# Set to "true" to use real AWS services, "false" for mock mode
USE_AWS=false

# AWS Configuration (only needed when USE_AWS=true)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock Model ID
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# DynamoDB Table Names
DYNAMODB_SCHEMES_TABLE=yojanasetu-schemes
DYNAMODB_CONVERSATIONS_TABLE=yojanasetu-conversations

# S3 Knowledge Base Bucket
S3_KNOWLEDGE_BUCKET=yojanasetu-knowledge-base

# Server
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
